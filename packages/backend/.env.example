
# Database
# PostgreSQL connection string
# See: https://pris.ly/d/connection-strings
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?schema=public"

# Authentication
# Secret used for signing JWTs — use a long, random string
JWT_PASSPHRASE="change-me-to-a-random-secret"

# Server
# Port the Fastify server listens on (default: 3000)
# PORT=3000

# Set to false for local development without HTTPS (default: true)
SECURE_COOKIES=false
